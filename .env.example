# ==========================================
# TeleBot Platform - Environment Configuration
# ==========================================

# --- Main Engine (Backend) ---
PORT=3000
JWT_SECRET=your-super-secret-key-here
DATABASE_URL="file:./data/telegram-bot.db"
CORS_ORIGIN=http://localhost:5173

# --- Telegram Bot Settings ---
TELEGRAM_BOT_TOKEN=your-bot-token-here
TELEGRAM_BOT_USERNAME=your-bot-username-here

# --- License Validation Settings ---
LICENSE_KEY=
LICENSE_SERVER_URL=http://localhost:3001

# --- Licensing Server Admin Credentials (Only for license-server) ---
# ADMIN_API_KEY=your-licensing-server-admin-key-here
